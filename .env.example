# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit it.
# .env.example documents what variables are required; commit it freely.

# ── RPC endpoint ──────────────────────────────────────────────────────────────
# An HTTP URL for a Sepolia node.  Free options:
#   Alchemy  — https://dashboard.alchemy.com  (create an app → Sepolia)
#   Infura   — https://app.infura.io          (create a project → Sepolia)
#   Public   — https://rpc.sepolia.org        (no sign-up, rate-limited)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE

# ── Deployer private key ──────────────────────────────────────────────────────
# THROWAWAY WALLET ONLY — generate a fresh one with:  cast wallet new
# Fund it with free Sepolia ETH before deploying (see README).
# NEVER use a wallet that holds real mainnet funds.
# Include the 0x prefix.
PRIVATE_KEY=0xYOUR_THROWAWAY_PRIVATE_KEY_HERE

# ── Etherscan API key ─────────────────────────────────────────────────────────
# Required for --verify (publishes source code to Sepolia Etherscan).
# Free account at https://etherscan.io/register → API Keys → Add.
# The same key works for both mainnet and Sepolia Etherscan.
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE
